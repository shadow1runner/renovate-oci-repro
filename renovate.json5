{
    $schema: 'https://docs.renovatebot.com/renovate-schema.json',
    extends: [
        'config:best-practices',
        ':rebaseStalePrs',
    ],
    argocd: {
        managerFilePatterns: [
            '/\\.ya?ml$/',
        ],
    },
    kubernetes: {
        "managerFilePatterns": ["/k8s/.+\\.yam?l$/"]
    },
    kustomize: {
        "pinDigests": false
    },
    packageRules: [
        {
            description: 'Automatically merge minor and patch-level updates',
            matchUpdateTypes: [
                'minor',
                'patch',
                'digest',
            ],
            automerge: true,
            automergeType: 'branch',
        },
        {
            description: 'Disable pinning digests as renovate errors out otherwise, https://github.com/renovatebot/renovate/discussions/28134#discussioncomment-8956047',
            "matchDatasources": [
                "docker"
            ],
            "pinDigests": true
        },
    ],
}
